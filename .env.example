# =============================================================================
# FlavorMap - Environment Variables
# Copy this file to .env and update values
# =============================================================================

# --- Django Settings ---
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=django-insecure-change-me-in-production-!@#$%^&*()
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api

# --- CORS Settings ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Database (PostgreSQL) ---
POSTGRES_DB=flavormap
POSTGRES_USER=flavormap
POSTGRES_PASSWORD=flavormap
DATABASE_URL=postgres://flavormap:flavormap@db:5432/flavormap

# --- MinIO (Object Storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_NAME=flavormap-media

# --- Docker Configuration ---
DOCKER_TARGET=development
API_PORT=8000
WEB_PORT=3000
DB_PORT=5432
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Next.js Web ---
NEXT_PUBLIC_API_URL=http://localhost:8000
